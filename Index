<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>AIR - Free Direct</title>
    
    <script src="https://unpkg.com/peerjs@1.4.7/dist/peerjs.min.js"></script>
    
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect width=%22100%22 height=%22100%22 rx=%2220%22 fill=%22%235b5fc7%22/><text y=%22.9em%22 font-size=%2270%22 fill=%22white%22 font-family=%22sans-serif%22 font-weight=%22bold%22 x=%225%22>AIR</text></svg>">

    <style>
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        body { 
            font-family: 'Segoe UI', system-ui, sans-serif; margin: 0; height: 100vh; 
            background: #0d0d0d; color: white; display: flex; flex-direction: column; overflow: hidden;
        }

        /* Top Bar */
        header { 
            padding: 15px; background: #1f1f1f; display: flex; align-items: center; gap: 10px;
            border-bottom: 1px solid #333; justify-content: space-between;
        }

        #id-display { font-size: 11px; color: #7f85f5; background: rgba(127, 133, 245, 0.1); padding: 5px 10px; border-radius: 5px; }

        /* Connection Box */
        #connect-box { padding: 15px; background: #151515; display: flex; gap: 8px; border-bottom: 1px solid #222; }
        input { flex: 1; padding: 10px; border-radius: 8px; border: 1px solid #333; background: #000; color: white; outline: none; font-size: 14px; }

        /* Chat Window */
        #chat-window { flex: 1; overflow-y: auto; padding: 15px; display: flex; flex-direction: column; gap: 12px; }

        .msg { max-width: 80%; padding: 10px 14px; border-radius: 15px; font-size: 14px; line-height: 1.4; position: relative; }
        .sent { align-self: flex-end; background: #3b3c51; border: 1px solid #5b5fc7; border-bottom-right-radius: 2px; }
        .received { align-self: flex-start; background: #2d2d2d; border-bottom-left-radius: 2px; }
        .chat-img { max-width: 100%; border-radius: 8px; margin-top: 5px; }

        /* Input Area */
        .input-area { padding: 10px; background: #1f1f1f; display: flex; gap: 8px; align-items: flex-end; }
        textarea { flex: 1; padding: 10px; border-radius: 10px; border: 1px solid #333; background: #000; color: white; resize: none; height: 42px; outline: none; }
        .btn { background: #2d2d2d; color: white; border: 1px solid #444; width: 42px; height: 42px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 18px; cursor: pointer; }
        
        .status { font-size: 10px; text-align: center; color: #555; margin-bottom: 5px; }
    </style>
</head>
<body>

    <header>
        <div style="display:flex; align-items:center; gap:8px;">
            <svg width="30" height="30" viewBox="0 0 100 100"><rect width="100" height="100" rx="20" fill="#5b5fc7"/><text x="50%" y="65%" text-anchor="middle" fill="white" font-weight="bold" font-size="40">AIR</text></svg>
            <b>AIR Direct</b>
        </div>
        <div id="id-display">Generating ID...</div>
    </header>

    <div id="connect-box">
        <input type="text" id="remote-id" placeholder="Paste friend's ID here...">
        <button class="btn" onclick="connectToPeer()" style="color: #6bb700;">🔌</button>
    </div>

    <div id="chat-window">
        <div class="status">Waiting for connection...</div>
    </div>

    <div class="input-area">
        <button class="btn" onclick="document.getElementById('fileInput').click()">+</button>
        <input type="file" id="fileInput" hidden accept="image/*" onchange="sendImage(this)">
        <textarea id="msgInput" placeholder="Message..."></textarea>
        <button class="btn" style="color: #5b5fc7;" onclick="sendMessage()">➤</button>
    </div>

    <script>
        const peer = new Peer();
        let conn;

        // When your ID is generated
        peer.on('open', (id) => {
            document.getElementById('id-display').innerText = "My ID: " + id;
            console.log('My peer ID is: ' + id);
        });

        // When someone connects to YOU
        peer.on('connection', (c) => {
            conn = c;
            setupChat();
        });

        // Function to connect to someone else
        function connectToPeer() {
            const id = document.getElementById('remote-id').value;
            if (!id) return alert("Enter an ID first!");
            conn = peer.connect(id);
            setupChat();
        }

        function setupChat() {
            conn.on('open', () => {
                addStatus("Connected to friend!");
                document.getElementById('connect-box').style.display = "none";
            });

            conn.on('data', (data) => {
                displayMsg(data, 'received');
            });
        }

        function sendMessage() {
            const input = document.getElementById('msgInput');
            if (!input.value.trim() || !conn) return;

            const data = { type: 'text', content: input.value, time: new Date().toLocaleTimeString([], {hour: '2-digit', minute: '2-digit'}) };
            conn.send(data);
            displayMsg(data, 'sent');
            input.value = "";
        }

        function sendImage(input) {
            if (input.files && input.files[0] && conn) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const data = { type: 'image', content: e.target.result, time: new Date().toLocaleTimeString([], {hour: '2-digit', minute: '2-digit'}) };
                    conn.send(data);
                    displayMsg(data, 'sent');
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function displayMsg(data, side) {
            const win = document.getElementById('chat-window');
            const div = document.createElement('div');
            div.className = `msg ${side}`;
            
            if (data.type === 'text') {
                div.innerText = data.content;
            } else {
                div.innerHTML = `<img src="${data.content}" class="chat-img" onclick="window.open(this.src)">`;
            }

            const timeSpan = document.createElement('div');
            timeSpan.style.fontSize = "9px";
            timeSpan.style.color = "#888";
            timeSpan.style.marginTop = "5px";
            timeSpan.innerText = data.time;
            div.appendChild(timeSpan);

            win.appendChild(div);
            win.scrollTop = win.scrollHeight;
        }

        function addStatus(text) {
            const div = document.createElement('div');
            div.className = "status";
            div.innerText = text;
            document.getElementById('chat-window').appendChild(div);
        }
    </script>
</body>
</html>
